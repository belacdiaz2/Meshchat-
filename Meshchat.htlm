<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>MeshChat Web Simulator v2.5</title>
    <style>
        :root {
            --bg-main: #0b111e;
            --bg-card: #151f32;
            --accent: #00d2ff;
            --text-main: #ffffff;
            --text-muted: #8a99ad;
            --success: #00ff87;
        }

        body {
            margin: 0;
            font-family: 'Segoe UI', Roboto, sans-serif;
            background-color: var(--bg-main);
            color: var(--text-main);
            display: flex;
            flex-direction: column;
            align-items: center;
            min-height: 100vh;
            padding: 10px;
            box-sizing: border-box;
        }

        .container {
            width: 100%;
            max-width: 450px;
            background: var(--bg-card);
            border-radius: 16px;
            padding: 20px;
            box-shadow: 0 8px 32px rgba(0,0,0,0.3);
            box-sizing: border-box;
        }

        header {
            text-align: center;
            margin-bottom: 20px;
        }

        header h1 {
            font-size: 1.4rem;
            color: var(--accent);
            margin: 0;
            letter-spacing: 1px;
        }

        header p {
            font-size: 0.85rem;
            color: var(--text-muted);
            margin: 5px 0 0 0;
        }

        /* Área del Radar Visual */
        .radar-container {
            position: relative;
            width: 160px;
            height: 160px;
            margin: 0 auto 20px auto;
            border: 2px solid rgba(0, 210, 255, 0.2);
            border-radius: 50%;
            overflow: hidden;
        }

        .radar-sweep {
            position: absolute;
            width: 100%;
            height: 100%;
            background: conic-gradient(from 0deg, rgba(0, 210, 255, 0.15) 0deg, transparent 90deg);
            border-radius: 50%;
            animation: sweep 4s linear infinite;
        }

        .node-dot {
            position: absolute;
            width: 12px;
            height: 12px;
            background-color: var(--accent);
            border-radius: 50%;
            box-shadow: 0 0 10px var(--accent);
            transform: translate(-50%, -50%);
        }

        .node-dot.me { background-color: var(--success); box-shadow: 0 0 10px var(--success); top: 70%; left: 30%; }
        .node-dot.b { top: 40%; left: 50%; }
        .node-dot.c { top: 25%; left: 75%; }

        @keyframes sweep {
            from { transform: rotate(0deg); }
            to { transform: rotate(360deg); }
        }

        /* Historial de Chat */
        .chat-box {
            height: 250px;
            background: rgba(0,0,0,0.2);
            border-radius: 8px;
            padding: 12px;
            overflow-y: auto;
            margin-bottom: 15px;
            border: 1px solid rgba(255,255,255,0.05);
            font-size: 0.95rem;
        }

        .msg { margin-bottom: 10px; line-height: 1.4; padding: 4px 0; border-bottom: 1px solid rgba(255,255,255,0.02); }
        .msg.system { color: var(--text-muted); font-style: italic; font-size: 0.85rem; }
        .msg.hop { color: var(--accent); font-weight: bold; padding-left: 10px; }
        .msg.success { color: var(--success); padding-left: 10px; }
        .msg.user { color: #fff; }

        /* Controles de entrada */
        .input-area {
            display: flex;
            gap: 10px;
        }

        input {
            flex: 1;
            background: #0b111e;
            border: 1px solid rgba(255,255,255,0.1);
            border-radius: 8px;
            padding: 12px;
            color: #fff;
            font-size: 1rem;
            outline: none;
        }

        input:focus { border-color: var(--accent); }

        .btn-group {
            display: flex;
            gap: 10px;
            margin-top: 10px;
            width: 100%;
        }

        button {
            flex: 1;
            background: var(--accent);
            color: #0b111e;
            border: none;
            border-radius: 8px;
            padding: 12px;
            font-weight: bold;
            font-size: 1rem;
            cursor: pointer;
        }

        button.clear-btn {
            background: #ff4b4b;
            color: white;
            max-width: 100px;
        }
    </style>
</head>
<body>

<div class="container">
    <header>
        <h1>MeshChat Simulator</h1>
        <p>Con Almacenamiento Local Fijo</p>
    </header>

    <div class="radar-container">
        <div class="radar-sweep"></div>
        <div class="node-dot me" title="Tú (Nodo A)"></div>
        <div class="node-dot b" title="Vecino Puente B"></div>
        <div class="node-dot c" title="Amigo Lejano C"></div>
    </div>

    <div class="chat-box" id="chatBox"></div>

    <div class="input-area">
        <input type="text" id="msgInput" placeholder="Escribe un mensaje encriptado..." autocomplete="off">
    </div>
    
    <div class="btn-group">
        <button id="sendBtn">Enviar Paquete</button>
        <button id="clearBtn" class="clear-btn">Limpiar</button>
    </div>
</div>

<script>
    const chatBox = document.getElementById('chatBox');
    const msgInput = document.getElementById('msgInput');
    const sendBtn = document.getElementById('sendBtn');
    const clearBtn = document.getElementById('clearBtn');

    // Datos de topología fija
    const rangoMaximo = 20; 
    const posiciones = { me: 0, vecinoB: 15, amigoC: 30 };

    // --- CARGAR HISTORIAL AL INICIAR ---
    window.addEventListener('DOMContentLoaded', () => {
        const historialGuardado = localStorage.getItem('mesh_history');
        if (historialGuardado) {
            chatBox.innerHTML = historialGuardado;
        } else {
            // Mensaje por defecto si la memoria está completamente vacía
            chatBox.innerHTML = '<div class="msg system">[SISTEMA] Canal seguro inicializado. Vecino_Puente_B detectado en rango.</div>';
        }
        chatBox.scrollTop = chatBox.scrollHeight;
    });

    function guardarHistorial() {
        // Guarda todo el HTML que está dentro de la caja de chat en el almacenamiento del navegador
        localStorage.setItem('mesh_history', chatBox.innerHTML);
    }

    function appendMessage(text, type) {
        const msgDiv = document.createElement('div');
        msgDiv.className = `msg ${type}`;
        const time = new Date().toLocaleTimeString([], {hour: '2-digit', minute:'2-digit', second:'2-digit'});
        msgDiv.innerHTML = `[${time}] ${text}`;
        chatBox.appendChild(msgDiv);
        chatBox.scrollTop = chatBox.scrollHeight;
        guardarHistorial(); // Guardar automáticamente con cada evento
    }

    function procesarEnvio() {
        const texto = msgInput.value.trim();
        if (!texto) return;

        appendMessage(`<b>Tú:</b> ${texto}`, 'user');
        msgInput.value = '';

        // Algoritmo de saltos simulados
        setTimeout(() => {
            const distanciaAB = Math.abs(posiciones.me - posiciones.vecinoB);
            if (distanciaAB <= rangoMaximo) {
                appendMessage("🔀 Saltando a través de [Vecino_Puente_B]...", "hop");
                
                setTimeout(() => {
                    const distanciaBC = Math.abs(posiciones.vecinoB - posiciones.amigoC);
                    if (distanciaBC <= rangoMaximo) {
                        appendMessage("✅ Entregado a [Amigo_Lejano_C].", "success");
                    } else {
                        appendMessage("❌ Error: Caída del nodo C.", "system");
                    }
                }, 800);
            } else {
                appendMessage("❌ Error: Sin conexión con puente intermedio.", "system");
            }
        }, 500);
    }

    // Evento para borrar la base de datos local
    clearBtn.addEventListener('click', () => {
        if(confirm("¿Quieres borrar todo el historial del chat local?")) {
            localStorage.removeItem('mesh_history');
            chatBox.innerHTML = '<div class="msg system">[SISTEMA] Historial borrado de la memoria local.</div>';
        }
    });

    sendBtn.addEventListener('click', procesarEnvio);
    msgInput.addEventListener('keypress', (e) => {
        if (e.key === 'Enter') procesarEnvio();
    });
</script>

</body>
</html>
